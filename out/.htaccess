# ----------------------------------------------------------------------
# Cache Control & Versioning Configurations for Next.js Export
# ----------------------------------------------------------------------

<IfModule mod_headers.c>
  # 1. HTML, TXT, and JSON files must NEVER be cached by browsers.
  # This ensures returning users immediately download the new index.html which references new JS/CSS build chunks.
  <FilesMatch "\.(html|htm|json|txt)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # 2. Next.js Static Assets (JS, CSS, and Fonts) contain unique build/content hashes in their filenames.
  # These can be cached forever by browsers because updating the site changes their filenames.
  <FilesMatch "\.(css|js|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # 3. Static Media / Images (PNG, JPG, SVG, ICO)
  # Give them a short/moderate cache lifetime or require validation so updates to assets are fetched.
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>
</IfModule>
